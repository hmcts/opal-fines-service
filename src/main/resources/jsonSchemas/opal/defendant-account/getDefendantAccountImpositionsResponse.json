{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Get Defendant Account Impositions Response",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "impositions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "date_added": {
            "type": "string",
            "format": "date"
          },
          "imposition": {
            "$ref": "../common-objects/resultReference.json"
          },
          "creditor": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "creditor_account_id": {
                "type": "integer"
              },
              "account_type": {
                "type": "string",
                "enum": ["MN", "MJ", "CF"]
              },
              "display_name": {
                "type": "string",
                "enum": ["Minor Creditor", "Major Creditor", "Central Fund"]
              },
              "major_creditor_id": {
                "type": ["integer", "null"]
              },
              "minor_creditor_party_id": {
                "type": ["integer", "null"]
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "creditor_account_id",
              "account_type",
              "display_name",
              "name"
            ]
          },
          "imposed_amount": {
            "type": "number",
            "minimum": 0
          },
          "paid_amount": {
            "type": "number",
            "minimum": 0
          },
          "balance": {
            "type": "number",
            "minimum": 0
          },
          "date_imposed": {
            "type": "string",
            "format": "date"
          },
          "offence": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": ["integer", "null"]
              },
              "code": {
                "type": ["string", "null"]
              },
              "title": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "title"
            ]
          },
          "imposed_by": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "court_id": {
                "type": "integer"
              },
              "court_code": {
                "type": ["integer", "null"]
              },
              "court_name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "court_id",
              "court_name"
            ]
          },
          "imposition_id": {
            "type": "integer"
          }
        },
        "required": [
          "date_added",
          "imposition",
          "creditor",
          "imposed_amount",
          "paid_amount",
          "balance",
          "date_imposed",
          "offence",
          "imposition_id"
        ]
      }
    }
  },
  "required": [
    "impositions"
  ]
}
