{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/opal-fines-service.history-items.schema.json",
  "title": "Get Defendant Account History Legacy Response",
  "type": "object",
  "properties": {
    "history_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/defendantAccountHistoryItem"
      }
    }
  },
  "$defs": {
    "defendantAccountHistoryItem": {
      "title": "historyItem",
      "type": "object",
      "required": ["posted_details", "type", "details"],
      "properties": {
        "posted_details": {
          "$ref": "./common-objects/postedDetailsLegacy.json"
        },
        "type": {
          "type": "string",
          "description": "History item type.",
          "enum": ["Amendment", "Enforcement", "Financial", "Note", "Payment terms"]
        },
        "details": {
          "oneOf": [
            {
              "$ref": "./common-objects/amendmentTypeLegacy.json"
            },
            {
              "$ref": "#/$defs/enforcementDetails"
            },
            {
              "$ref": "#/$defs/noteDetails"
            },
            {
              "$ref": "#/$defs/defendantTransactionDetails"
            },
            {
              "$ref": "./common-objects/paymentTermsLegacy.json"
            }
          ],
          "description": "History item details"
        },
        "amount": {
          "$ref": "./common-objects/monetaryNegativeOrPositive.json"
        }
      }
    },
    "enforcementDetails": {
      "type": "object",
      "required": ["enforcement_action"],
      "properties": {
        "enforcement_action": {
          "type": "string"
        },
        "days_in_default": {
          "type": "integer"
        },
        "warrant_number": {
          "type": "string"
        },
        "hearing_date": {
          "type": "string",
          "format": "date"
        },
        "hearing_court": {
          "$ref": "./common-objects/courtReferenceLegacy.json"
        },
        "case_number": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "earliest_date_of_release": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "noteDetails": {
      "type": "object",
      "required": ["note_text"],
      "properties": {
        "note_text": {
          "type": "string"
        }
      }
    },
    "defendantTransactionDetails": {
      "title": "transactionDetails",
      "type": "object",
      "required": ["transaction_type"],
      "properties": {
        "transaction_type": {
          "$ref": "./common-objects/defendantTransactionTypeReferenceLegacy.json"
        },
        "payment_method": {
          "$ref": "./common-objects/paymentMethodReferenceLegacy.json"
        },
        "payment_reference": {
          "type": "string"
        },
        "additional_information": {
          "type": "string"
        },
        "write_off": {
          "$ref": "./common-objects/writeOffTypeReferenceLegacy.json"
        },
        "status": {
          "$ref": "./common-objects/defendantTransactionStatusReferenceLegacy.json"
        },
        "status_date": {
          "type": "string",
          "format": "date-time"
        },
        "associated_record_type": {
          "type": "string"
        },
        "associated_record_id": {
          "type": "string"
        },
        "account_number": {
          "type": "string"
        },
        "sending_court": {
          "type": "string"
        },
        "imposition_date": {
          "type": "string",
          "format": "date"
        },
        "imposition_code": {
          "type": "string"
        },
        "amount_imposed": {
          "$ref": "./common-objects/monetaryZeroOrNegative.json"
        }
      }
    }
  }
}
