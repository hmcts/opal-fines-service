{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/opal-fines-service.history-items.schema.json",
  "title": "Get Major Creditor Account History Legacy Response",
  "type": "object",
  "properties": {
    "history_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/majorCreditorHistoryItem"
      }
    }
  },
  "$defs": {
    "majorCreditorHistoryItem": {
      "title": "historyItem",
      "type": "object",
      "required": ["posted_details", "type", "details"],
      "properties": {
        "posted_details": {
          "$ref": "./common-objects/postedDetailsLegacy.json"
        },
        "type": {
          "type": "string",
          "description": "History item type.",
          "enum": ["Financial", "Note"]
        },
        "details": {
          "oneOf": [
            {
              "$ref": "#/$defs/noteDetails"
            },
            {
              "$ref": "#/$defs/creditorTransactionDetails"
            }
          ],
          "description": "History item details"
        },
        "amount": {
          "$ref": "./common-objects/monetaryNegativeOrPositive.json"
        }
      }
    },
    "noteDetails": {
      "type": "object",
      "required": ["note_text"],
      "properties": {
        "note_text": {
          "type": "string"
        }
      }
    },
    "creditorTransactionDetails": {
      "title": "transactionDetails",
      "type": "object",
      "required": ["transaction_type"],
      "properties": {
        "transaction_type": {
          "$ref": "./common-objects/creditorTransactionTypeReferenceLegacy.json"
        },
        "payment_reference": {
          "type": "string"
        },
        "status": {
          "$ref": "./common-objects/creditorTransactionStatusReferenceLegacy.json"
        },
        "status_date": {
          "type": "string",
          "format": "date-time"
        },
        "associated_record_type": {
          "type": "string"
        },
        "associated_record_id": {
          "type": "string"
        },
        "account_number": {
          "type": "string"
        },
        "defendant_account_number": {
          "type": "string"
        },
        "defendant_account_id": {
          "type": "integer"
        }
      }
    }
  }
}
