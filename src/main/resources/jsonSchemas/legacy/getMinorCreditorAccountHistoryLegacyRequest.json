{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Get Minor Creditor Account History Legacy Request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "creditor_account_id": {
      "type": "string",
      "minLength": 1
    },
    "from_date": {
      "type": "string",
      "format": "date"
    },
    "to_date": {
      "type": "string",
      "format": "date"
    },
    "item_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Amendment",
          "Financial",
          "Note"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    }

  },
  "required": [
    "creditor_account_id"
  ]
}
