{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opal-fines-service/postMinorCreditorAccountsSearchLegacyRequest.json",
  "type": "object",
  "allOf": [
    {
      "required": ["active_accounts_only"]
    },
    {
      "oneOf": [
        { "required": ["account_number"] },
        { "required": ["creditor"] }
      ]
    }
  ],
  "properties": {
    "business_unit_ids": {
      "type": "array",
      "description": "One or more business unit IDs",
      "minItems": 1,
      "items": {
        "type": "integer",
        "description": "Unique identifier for a business unit"
      }
    },
    "active_accounts_only": {
      "type": "boolean",
      "description": "Indicator if active accounts only are to be included in the search"
    },
    "account_number": {
      "type": "string",
      "description": "The account number for financial records."
    },
    "creditor": {
      "$ref": "#/$defs/creditor",
      "description": "Minor Creditor search parameters"
    }
  },
  "$defs": {
    "creditor": {
      "type": "object",
      "required": ["organisation"],
      "properties": {
        "address_line_1": {
          "type": "string",
          "description": "Address Line 1"
        },
        "postcode": {
          "type": "string",
          "description": "The postcode associated with the creditor"
        },
        "organisation": {
          "type": "boolean",
          "description": "Indicates if the creditor is an organisation (true) or an individual (false)"
        },
        "organisation_name": {
          "type": "string",
          "description": "Name of the organisation"
        },
        "exact_match_organisation_name": {
          "type": "boolean",
          "description": "Apply exact match for organisation name"
        },
        "surname": {
          "type": "string",
          "description": "Surname of the individual"
        },
        "forenames": {
          "type": "string",
          "description": "Forenames of the individual"
        },
        "exact_match_surname": {
          "type": "boolean",
          "description": "Apply exact match for surname"
        },
        "exact_match_forenames": {
          "type": "boolean",
          "description": "Apply exact match for forenames"
        }
      },
      "oneOf": [
        {
          "properties": {
            "organisation": { "const": true },
            "surname": false,
            "forenames": false,
            "exact_match_surname": false,
            "exact_match_forenames": false
          },
          "anyOf": [
            { "required": ["organisation_name"] },
            { "required": ["address_line_1"] },
            { "required": ["postcode"] }
          ]
        },
        {
          "properties": {
            "organisation": { "const": false },
            "organisation_name": false,
            "exact_match_organisation_name": false
          },
          "anyOf": [
            { "required": ["surname"] },
            { "required": ["address_line_1"] },
            { "required": ["postcode"] }
          ]
        }
      ],
      "allOf": [
        {
          "if": { "required": ["forenames"] },
          "then": { "required": ["surname"] }
        }
      ],
      "additionalProperties": false
    }
  }
}
