        <xsd:element name="vehicle_registration_mark" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="document_language" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="hearing_language" type="xsd:string" minOccurs="0" maxOccurs="1"/>
