        <xsd:element name="post_code" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="telephone_number_home" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="telephone_number_business" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="telephone_number_mobile" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="email_address_1" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="email_address_2" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="debtor_detail" type="debtor_detail" minOccurs="0" maxOccurs="1"/>
      </xsd:sequence>
    </xsd:choice>
  </xsd:complexType>
</xsd:schema>
