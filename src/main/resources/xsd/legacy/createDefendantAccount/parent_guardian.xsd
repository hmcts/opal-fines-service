        <xsd:element name="company_name" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="surname" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="forenames" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="dob" type="xsd:date" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="national_insurance_number" type="xsd:string" minOccurs="0" maxOccurs="1"/>
        <xsd:element name="address_line_1" type="xsd:string" minOccurs="1" maxOccurs="1"/>
