{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>hmcts/.github:renovate-config"
  ],
  "packageRules": [
    {
      "description": "Lock the cucumber dependencies to version 7.23.0 for serenity-bdd gradle plugin 4.2.34",
      "matchPackageNames": ["cucumber-core", "cucumber-java", "cucumber-junit", "io.cucumber{/,}**"],
      "rangeStrategy": "pin",
      "allowedVersions": "7.23.0",
      "versioning": "fixed"
    },
    {
      "description": "Keep com.networknt:json-schema-validator on v1 because JsonSchemaValidationService and DefendantDto still depend on the pre-v2 API removed in later major versions",
      "matchManagers": ["gradle"],
      "matchPackageNames": ["com.networknt:json-schema-validator", "com.networknt{/,}**"],
      "allowedVersions": "<2.0.0"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["postgres"],
      "enabled": false
    },
    {
      "matchManagers": ["helm"],
      "matchPackageNames": ["postgresql", "userServicePostgresql"],
      "enabled": false
    },
    {
      "matchManagers": ["gradle-wrapper"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchManagers": ["gradle"],
      "matchPackageNames": ["org.hibernate.orm:hibernate-jpamodelgen"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "springdoc 3.x requires Spring Boot 4.x; keep on 2.x until Boot 4 migration",
      "matchManagers": ["gradle"],
      "matchPackageNames": ["org.springdoc:springdoc-openapi-starter-webmvc-ui"],
      "allowedVersions": "<3.0.0"
    },
    {
      "description": "opal-common-lib updates are coordinated manually across consuming services",
      "matchManagers": ["gradle"],
      "matchPackageNames": ["uk.gov.hmcts:opal-common-lib"],
      "enabled": false
    },
    {
      "description": "opal-logging-service-integration-lib updates are coordinated manually across consuming services",
      "matchManagers": ["gradle"],
      "matchPackageNames": ["uk.gov.hmcts:opal-logging-service-integration-lib"],
      "enabled": false
    },
    {
      "description": "Group Tomcat embed dependencies",
      "matchManagers": ["gradle"],
      "matchPackageNames": [
        "org.apache.tomcat.embed:tomcat-embed-core",
        "org.apache.tomcat.embed:tomcat-embed-websocket",
        "org.apache.tomcat.embed:tomcat-embed-el",
        "org.apache.tomcat:tomcat-annotations-api"
      ],
      "groupName": "Tomcat Embed",
      "groupSlug": "tomcat-embed"
    },
    {
      "description": "Group all Gradle plugins - Minor/Patch",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Gradle Plugins - Minor/Patch",
      "matchPackageNames": [
        "/^org\\.springframework\\.boot$/",
        "/^io\\.spring\\.dependency-management$/",
        "/^com\\.github\\.ben-manes\\.versions$/",
        "/^org\\.sonarqube$/",
        "/^uk\\.gov\\.hmcts\\.java$/",
        "/^org\\.flywaydb\\.flyway$/",
        "/^net\\.serenity-bdd\\.serenity-gradle-plugin$/",
        "/^org\\.openapi.generator$/"
      ]
    },
    {
      "description": "Group all Gradle plugins - Major",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "groupName": "Gradle Plugins - Major",
      "matchPackageNames": [
        "/^org\\.springframework\\.boot$/",
        "/^io\\.spring\\.dependency-management$/",
        "/^com\\.github\\.ben-manes\\.versions$/",
        "/^org\\.sonarqube$/",
        "/^uk\\.gov\\.hmcts\\.java$/",
        "/^org\\.flywaydb\\.flyway$/",
        "/^net\\.serenity-bdd\\.serenity-gradle-plugin$/",
        "/^org\\.openapi.generator$/"
      ]
    },
    {
      "description": "Group all Spring dependencies - Minor/Patch",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Spring Dependencies - Minor/Patch",
      "matchPackageNames": [
        "org.springframework{/,}**"
      ]
    },
    {
      "description": "Group all Spring dependencies - Major",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "groupName": "Spring Dependencies - Major",
      "matchPackageNames": [
        "org.springframework{/,}**"
      ]
    },
    {
      "description": "Group all test dependencies - Minor/Patch",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Test Dependencies - Minor/Patch",
      "matchPackageNames": [
        "/^io\\.cucumber.*/",
        "/^net\\.serenity-bdd.*/",
        "/^org\\.junit.*/",
        "/^org\\.mockito.*/"
      ]
    },
    {
      "description": "Group all test dependencies - Major",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "groupName": "Test Dependencies - Major",
      "matchPackageNames": [
        "/^io\\.cucumber.*/",
        "/^net\\.serenity-bdd.*/",
        "/^org\\.junit.*/",
        "/^org\\.mockito.*/"
      ]
    },
    {
      "description": "Group all database dependencies - Minor/Patch",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Database Dependencies - Minor/Patch",
      "matchPackageNames": [
        "/^org\\.flywaydb.*/",
        "/^org\\.postgresql.*/"
      ]
    },
    {
      "description": "Group all database dependencies - Major",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "groupName": "Database Dependencies - Major",
      "matchPackageNames": [
        "/^org\\.flywaydb.*/",
        "/^org\\.postgresql.*/"
      ]
    },
    {
      "description": "Group all OpenAPI/Swagger dependencies - Minor/Patch",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "OpenAPI/Swagger Dependencies - Minor/Patch",
      "matchPackageNames": [
        "/^org\\.openapi.*/",
        "/^io\\.swagger.*/"
      ]
    },
    {
      "description": "Group all OpenAPI/Swagger dependencies - Major",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "groupName": "OpenAPI/Swagger Dependencies - Major",
      "matchPackageNames": [
        "/^org\\.openapi.*/",
        "/^io\\.swagger.*/"
      ]
    },
    {
      "description": "Group all logging dependencies - Minor/Patch",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Logging Dependencies - Minor/Patch",
      "matchPackageNames": [
        "/.*log4j.*/",
        "/.*slf4j.*/",
        "/.*logback.*/",
        "/.*logging.*/"
      ]
    },
    {
      "description": "Group all logging dependencies - Major",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "groupName": "Logging Dependencies - Major",
      "matchPackageNames": [
        "/.*log4j.*/",
        "/.*slf4j.*/",
        "/.*logback.*/",
        "/.*logging.*/"
      ]
    }
  ],
  "description": "Schedule for Wednesdays only.",
  "schedule": [ "* * * * 3" ]
}
