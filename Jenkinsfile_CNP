  }

  afterAlways('smoketest:dev') {
    publishSmokeResults()
  }

  afterAlways('functionalTest:stg') {
    publishFunctionalResults()
  }
  afterAlways('smoketest:stg') {
    publishSmokeResults()
  }
}
